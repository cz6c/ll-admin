{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/comment-gate-session-start.mjs",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/comment-gate-track-edit.mjs",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/comment-gate-stop.mjs",
        "timeout": 15,
        "loop_limit": 1
      }
    ]
  }
}
